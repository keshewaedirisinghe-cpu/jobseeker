# Application
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-me-locally
APP_TIMEZONE=Asia/Colombo

# Database / queue
POSTGRES_DB=job_agent
POSTGRES_USER=job_agent
POSTGRES_PASSWORD=change-me-locally
DATABASE_URL=postgresql+psycopg://job_agent:change-me-locally@postgres:5432/job_agent
REDIS_URL=redis://redis:6379/0

# Runtime LLM - disabled until API billing/key is configured
LLM_ENABLED=false
OPENAI_API_KEY=
OPENAI_SCORING_MODEL=
OPENAI_PROPOSAL_MODEL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LLM_DAILY_COST_LIMIT_USD=1.00
LLM_PER_JOB_CALL_LIMIT=3

# Notifications - optional
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Submission/outreach - hard disabled defaults
API_WRITE_ENABLED=false
BROWSER_FILL_ENABLED=false
OUTREACH_SEND_ENABLED=false
